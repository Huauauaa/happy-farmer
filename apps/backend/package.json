{
  "name": "@happy-farmer/backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "nodemon --watch src --watch prisma --ext ts,prisma --exec \"pnpm prisma:push && pnpm build && node dist/index.js\"",
    "build": "pnpm prisma:generate && tsc -p tsconfig.json",
    "start": "pnpm prisma:push && node dist/index.js",
    "lint": "echo \"No lint configured for backend\"",
    "prisma:generate": "node ./scripts/run-prisma-command.mjs generate",
    "prisma:push": "node ./scripts/run-prisma-command.mjs db push"
  },
  "dependencies": {
    "@prisma/adapter-mariadb": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.21.2",
    "mariadb": "^3.5.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.18.6",
    "nodemon": "^3.1.14",
    "prisma": "^7.5.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
